# ─── Database ───────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5433/thadam_db
DB_USERNAME=thadam
DB_PASSWORD=thadam_password

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars-long
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ─── Google OAuth ───────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/login/oauth2/code/google
OAUTH2_FRONTEND_REDIRECT=http://localhost:3000/oauth2/redirect

# ─── Gemini AI ──────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_API_VERSION=v1beta
GEMINI_MODEL=gemini-2.5-flash

# ─── Spring ─────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ─── Security ───────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Stripe ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ─── Cloudinary (Optional, currently using Base64) ──────
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name